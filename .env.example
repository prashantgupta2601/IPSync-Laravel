APP_NAME=IPFC
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://your-app.onrender.com

LOG_CHANNEL=stack
LOG_LEVEL=error

# DATABASE (Render PostgreSQL)
DB_CONNECTION=pgsql
DB_HOST=
DB_PORT=5432
DB_DATABASE=
DB_USERNAME=
DB_PASSWORD=

# SESSION & CACHE
SESSION_DRIVER=file
SESSION_LIFETIME=120
SESSION_ENCRYPT=false

CACHE_STORE=file
QUEUE_CONNECTION=sync

# FILE STORAGE
FILESYSTEM_DISK=local

# MAIL
MAIL_MAILER=log
MAIL_FROM_ADDRESS="hello@ipfc.com"
MAIL_FROM_NAME="${APP_NAME}"

# REDIS (optional)
REDIS_HOST=127.0.0.1
REDIS_PORT=6379

APP_LOCALE=en
APP_FALLBACK_LOCALE=en